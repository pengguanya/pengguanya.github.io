<mxfile host="app.diagrams.net">
  <diagram name="The loops stack" id="loops-stack">
    <mxGraphModel dx="1414" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#111827;" value="The loops stack — and how the Workshop Agent design used them" vertex="1">
          <mxGeometry height="30" width="660" x="160" y="20" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#6b7280;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;A meta-tool isn&#39;t one loop. It&#39;s several, nested: each loop wraps the one inside it, and the outermost (hill-climbing) reaches in to improve them.&lt;/font&gt;" vertex="1">
          <mxGeometry height="44" width="610" x="190" y="54" as="geometry" />
        </mxCell>
        <mxCell id="loop4" parent="1" style="rounded=1;arcSize=4;html=1;fillColor=#fffbeb;strokeColor=#f59e0b;strokeWidth=2;verticalAlign=top;" value="" vertex="1">
          <mxGeometry height="566" width="800" x="90" y="128" as="geometry" />
        </mxCell>
        <mxCell id="loop3" parent="1" style="rounded=1;arcSize=5;html=1;fillColor=#f0fdfa;strokeColor=#14b8a6;strokeWidth=2;verticalAlign=top;" value="" vertex="1">
          <mxGeometry height="430" width="698" x="152" y="196" as="geometry" />
        </mxCell>
        <mxCell id="loop2" parent="1" style="rounded=1;arcSize=6;html=1;fillColor=#faf5ff;strokeColor=#a855f7;strokeWidth=2;verticalAlign=top;" value="" vertex="1">
          <mxGeometry height="294" width="576" x="214" y="264" as="geometry" />
        </mxCell>
        <mxCell id="loop1" parent="1" style="rounded=1;arcSize=8;html=1;fillColor=#eff6ff;strokeColor=#3b82f6;strokeWidth=2;verticalAlign=top;" value="" vertex="1">
          <mxGeometry height="158" width="428" x="276" y="332" as="geometry" />
        </mxCell>
        <mxCell id="reachin" edge="1" parent="1" source="loop4" style="endArrow=classic;html=1;dashed=1;curved=1;strokeColor=#b45309;strokeWidth=4;exitX=1.001;exitY=0.124;exitDx=0;exitDy=0;exitPerimeter=0;" value="">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="812" y="332" />
            </Array>
            <mxPoint x="846" y="216" as="sourcePoint" />
            <mxPoint x="700" y="418" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="reachinlabel" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=2;fontColor=#b45309;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Loop 4 reaches in&lt;br&gt;and rewrites the&lt;br&gt;inner loops&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="48" width="170" x="800" y="322" as="geometry" />
        </mxCell>
        <mxCell id="lbl4" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b style=&quot;color: rgb(180, 83, 9);&quot;&gt;④ ↺&amp;nbsp; Hill-climbing loop&lt;/b&gt; &amp;nbsp;—&amp;nbsp; past runs rewrite the harness, so it improves itself&lt;br&gt;&lt;span style=&quot;color: rgb(100, 116, 139);&quot;&gt;▸ workshop: each run sharpens the capture-and-rebuild skill for next time&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="46" width="708" x="112" y="140" as="geometry" />
        </mxCell>
        <mxCell id="lbl3" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;&lt;b style=&quot;color: rgb(15, 118, 110);&quot;&gt;③ ↺&amp;nbsp; Event-driven loop&lt;/b&gt; &amp;nbsp;—&amp;nbsp; a trigger starts it: a schedule, a webhook, a new file&lt;br&gt;&lt;span style=&quot;color: rgb(100, 116, 139);&quot;&gt;▸ workshop: the next workshop captures itself from a calendar invite&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="46" width="676" x="166" y="204" as="geometry" />
        </mxCell>
        <mxCell id="lbl2" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;b style=&quot;color: rgb(124, 58, 237);&quot;&gt;② ↺&amp;nbsp; Verification loop&lt;/b&gt; &amp;nbsp;—&amp;nbsp; a separate checker grades the output and sends it back&lt;br&gt;&lt;span style=&quot;color: rgb(100, 116, 139);&quot;&gt;▸ workshop: a scored test checks me; a second pass checks the course&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="46" width="623" x="219" y="276" as="geometry" />
        </mxCell>
        <mxCell id="lbl1" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b style=&quot;color: rgb(29, 78, 216);&quot;&gt;① ↺&amp;nbsp; Agent loop&lt;/b&gt;&lt;br&gt;reason → act → observe → repeat, until the goal is met&lt;br&gt;&lt;span style=&quot;color: rgb(100, 116, 139);&quot;&gt;▸ workshop: transcribe, snapshot, then build the tutor · notebook · test&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="402" x="289" y="340" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
