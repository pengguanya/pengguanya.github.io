        <mxCell id="exRightTitle" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#475569;" value="What it built — and I kept" vertex="1">
          <mxGeometry height="18" width="400" x="520" y="408" as="geometry" />
        </mxCell>
        <mxCell id="exRightText" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontColor=#334155;" value="A personal course: an &lt;b&gt;&lt;font color=&quot;#047857&quot;&gt;AI tutor&lt;/font&gt;&lt;/b&gt; for my questions, a &lt;b&gt;&lt;font color=&quot;#047857&quot;&gt;hands-on notebook&lt;/font&gt;&lt;/b&gt; to rebuild it, and a &lt;b&gt;&lt;font color=&quot;#047857&quot;&gt;scored test&lt;/font&gt;&lt;/b&gt; for my gaps." vertex="1">
