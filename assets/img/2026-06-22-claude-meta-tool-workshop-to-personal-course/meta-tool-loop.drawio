        <mxCell id="exLeftText" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontStyle=2;fontColor=#334155;" value="“Turn this 6AM AWS workshop — all config, no concepts — into a course I can actually learn from.”" vertex="1">
          <mxGeometry height="80" width="410" x="56" y="432" as="geometry" />
