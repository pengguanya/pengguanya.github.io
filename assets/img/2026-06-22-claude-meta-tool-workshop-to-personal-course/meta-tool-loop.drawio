<mxfile host="app.diagrams.net">
  <diagram name="Claude meta-tool loop" id="meta-tool-loop">
    <mxGraphModel dx="1414" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=27;fontStyle=1;fontColor=#111827;" value="Claude as a meta-tool through LOOP" vertex="1">
          <mxGeometry height="34" width="500" x="240" y="28" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#6b7280;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;You give it an outcome, not the steps. It builds its own tools, checks the result, and reshapes its whole approach until it holds.&lt;/font&gt;" vertex="1">
          <mxGeometry height="24" width="720" x="130" y="66" as="geometry" />
        </mxCell>
        <mxCell id="looplabel" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#7c3aed;letterSpacing=2;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;THE SELF-RESHAPING LOOP&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="322" x="312" y="130" as="geometry" />
        </mxCell>
        <mxCell id="nOutcome" parent="1" style="rounded=1;arcSize=20;whiteSpace=wrap;html=1;fillColor=#fbbf24;gradientColor=#d97706;strokeColor=none;fontColor=#ffffff;fontSize=15;fontStyle=1;" value="&lt;b&gt;AN OUTCOME&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;(not the steps)&lt;/font&gt;" vertex="1">
          <mxGeometry height="66" width="160" x="36" y="172" as="geometry" />
        </mxCell>
        <mxCell id="nFind" parent="1" style="rounded=1;arcSize=22;whiteSpace=wrap;html=1;fillColor=#faf9ff;strokeColor=#c4b5fd;strokeWidth=2;fontColor=#3730a3;fontSize=14;fontStyle=1;" value="Find (or re-think) a path" vertex="1">
          <mxGeometry height="66" width="120" x="252" y="172" as="geometry" />
        </mxCell>
        <mxCell id="nBuild" parent="1" style="rounded=1;arcSize=22;whiteSpace=wrap;html=1;fillColor=#faf9ff;strokeColor=#c4b5fd;strokeWidth=2;fontColor=#3730a3;fontSize=14;" value="&lt;b&gt;Build &amp;amp; run&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#6d28d9&quot; style=&quot;font-size: 13px;&quot;&gt;its own tools&lt;/font&gt;" vertex="1">
          <mxGeometry height="66" width="138" x="402" y="172" as="geometry" />
