        <mxCell id="e3" edge="1" parent="1" source="nBuild" style="endArrow=classic;html=1;strokeColor=#94a3b8;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="nCheck">
          <mxGeometry relative="1" as="geometry" />
