        <mxCell id="exLeftTitle" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#475569;" value="The outcome I gave it" vertex="1">
          <mxGeometry height="18" width="400" x="56" y="408" as="geometry" />
