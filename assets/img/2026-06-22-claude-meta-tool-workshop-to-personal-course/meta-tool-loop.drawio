        <mxCell id="e4" edge="1" parent="1" source="nCheck" style="endArrow=classic;html=1;strokeColor=#059669;strokeWidth=2.5;fontColor=#059669;fontStyle=1;fontSize=11;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="nMachine" value="holds ✓">
