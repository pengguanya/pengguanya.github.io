        <mxCell id="n4" parent="1" style="rounded=1;html=1;fillColor=#e3f1f3;strokeColor=#2f8f9d;fontColor=#1f2933;fontSize=13;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;Chemist · the assay decides&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;color: rgb(47, 116, 128);&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;a lighter human gate&lt;/font&gt;&lt;/span&gt;" vertex="1">
