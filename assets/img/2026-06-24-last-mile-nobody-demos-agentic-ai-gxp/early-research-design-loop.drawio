        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#5b6770;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;Ground truth is the next experiment, not a regulator&lt;/font&gt;" vertex="1">
