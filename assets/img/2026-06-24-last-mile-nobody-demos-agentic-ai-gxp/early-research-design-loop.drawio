        <mxCell id="n2" parent="1" style="rounded=1;html=1;fillColor=#ffffff;strokeColor=#c5cdd5;fontColor=#1f2933;fontSize=13;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;Score vs. constraints&lt;/b&gt;&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;color: rgb(91, 103, 112);&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;drug-likeness · synthesis · off-targets&lt;/font&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="64" width="230" x="250" y="120" as="geometry" />
